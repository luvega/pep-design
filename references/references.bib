@article{hartman_interpreting_2023,
	title = {Interpreting biologically informed neural networks for enhanced proteomic biomarker discovery and pathway analysis},
	url = {https://doi.org/10.1038/s41467-023-41146-4},
	doi = {10.1038/s41467-023-41146-4},
	abstract = {The incorporation of machine learning methods into proteomics workflows improves the identification of disease-relevant biomarkers and biological pathways. However, machine learning models, such as deep neural networks, typically suffer from lack of interpretability. Here, we present a deep learning approach to combine biological pathway analysis and biomarker identification to increase the interpretability of proteomics experiments. Our approach integrates a priori knowledge of the relationships between proteins and biological pathways and biological processes into sparse neural networks to create biologically informed neural networks. We employ these networks to differentiate between clinical subphenotypes of septic acute kidney injury and COVID-19, as well as acute respiratory distress syndrome of different aetiologies. To gain biological insight into the complex syndromes, we utilize feature attribution-methods to introspect the networks for the identification of proteins and pathways important for distinguishing between subtypes. The algorithms are implemented in a freely available open source Python-package (https://github.com/InfectionMedicineProteomics/BINN).},
	journal = {Nature Communications},
	author = {Hartman, Erik and Scott, Aaron M. and Karlsson, Christofer and Mohanty, Tirthankar and Vaara, Suvi T. and Linder, Adam and Malmström, Lars and Malmström, Johan},
	year = {2023},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 计算化学模型 EndNote Refs: 计算化学模型\#44 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}计算化学模型.Data{\textbackslash}PDF{\textbackslash}1946990652{\textbackslash}s41467-023-41146-4.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, import:EndNote全量, EndNote库:计算化学模型, 分类:AI药物设计\_蛋白与多肽},
}

@article{yang_design_2025,
	title = {Design of high-affinity binders to immune modulating receptors for cancer immunotherapy},
	url = {https://doi.org/10.1038/s41467-025-57192-z},
	doi = {10.1038/s41467-025-57192-z},
	abstract = {Immune receptors have emerged as critical therapeutic targets for cancer immunotherapy. Designed protein binders can have high affinity, modularity, and stability and hence could be attractive components of protein therapeutics directed against these receptors, but traditional Rosetta based protein binder methods using small globular scaffolds have difficulty achieving high affinity on convex targets. Here we describe the development of helical concave scaffolds tailored to the convex target sites typically involved in immune receptor interactions. We employed these scaffolds to design proteins that bind to TGFβRII, CTLA-4, and PD-L1, achieving low nanomolar to picomolar affinities and potent biological activity following experimental optimization. Co-crystal structures of the TGFβRII and CTLA-4 binders in complex with their respective receptors closely match the design models. These designs should have considerable utility for downstream therapeutic applications.},
	journal = {Nature Communications},
	author = {Yang, Wei and Hicks, Derrick R. and Ghosh, Agnidipta and Schwartze, Tristin A. and Conventry, Brian and Goreshnik, Inna and Allen, Aza and Halabiya, Samer F. and Kim, Chan Johng and Hinck, Cynthia S. and Lee, David S. and Bera, Asim K. and Li, Zhe and Wang, Yujia and Schlichthaerle, Thomas and Cao, Longxing and Huang, Buwei and Garrett, Sarah and Gerben, Stacey R. and Rettie, Stephen and Heine, Piper and Murray, Analisa and Edman, Natasha and Carter, Lauren and Stewart, Lance and Almo, Steven C. and Hinck, Andrew P. and Baker, David},
	year = {2025},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#134 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}1838096222{\textbackslash}2025-Nature Communic-Design of high-affinity b.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, protein design, molecular docking, TGF-beta, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:protein design {\textbar} molecular docking {\textbar} TGF-beta},
