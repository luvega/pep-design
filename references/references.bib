@article{li_yeast_2024,
	title = {Yeast surface display technology: {Mechanisms}, applications, and perspectives},
	doi = {10.1016/j.biotechadv.2024.108422},
	abstract = {Microbial cell surface display technology, which relies on genetically fusing heterologous target proteins to the cell wall through fusion with cell wall anchor proteins, has emerged as a promising and powerful method with diverse applications in biotechnology and biomedicine. Compared to classical intracellular or extracellular expression (secretion) systems, the cell surface display strategy stands out by eliminating the necessity for enzyme purification, overcoming substrate transport limitations, and demonstrating enhanced activity, stability, and selectivity. Unlike phage or bacterial surface display, the yeast surface display (YSD) system offers distinct advantages, including its large cell size, ease of culture and genetic manipulation, the use of generally regarded as safe (GRAS) host cell, the ability to ensure correct folding of complex eukaryotic proteins, and the potential for post-translational modifications. To date, YSD systems have found widespread applications in protein engineering, waste biorefineries, bioremediation, and the production of biocatalysts and biosensors. This review focuses on detailing various strategies and mechanisms for constructing YSD systems, providing a comprehensive overview of both fundamental principles and practical applications. Finally, the review outlines future perspectives for developing novel forms of YSD systems and explores potential applications in diverse fields.},
	journal = {Biotechnol Adv},
	author = {Li, Y. and Wang, X. and Zhou, N. Y. and Ding, J.},
	year = {2024},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#48 Local PDF Paths: [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, *Cell Surface Display Techniques/methods, Anchor protein, Bioremediation, Biotechnology/methods, competing financial interests or personal relationships that could have appeared, Protein Engineering/methods, Saccharomyces cerevisiae, Saccharomyces cerevisiae/genetics/metabolism, Scaffoldin, to influence the work reported in this paper., Whole cell biocatalyst, Yeast surface display, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计},
