@article{clark_enhancing_2023,
	title = {Enhancing antibody affinity through experimental sampling of non-deleterious {CDR} mutations predicted by machine learning},
	url = {https://doi.org/10.1038/s42004-023-01037-7},
	doi = {10.1038/s42004-023-01037-7},
	abstract = {The application of machine learning (ML) models to optimize antibody affinity to an antigen is gaining prominence. Unfortunately, the small and biased nature of the publicly available antibody-antigen interaction datasets makes it challenging to build an ML model that can accurately predict binding affinity changes due to mutations (ΔΔG). Recognizing these inherent limitations, we reformulated the problem to ask whether an ML model capable of classifying deleterious vs non-deleterious mutations can guide antibody affinity maturation in a practical setting. To test this hypothesis, we developed a Random Forest classifier (Antibody Random Forest Classifier or AbRFC) with expert-guided features and integrated it into a computational-experimental workflow. AbRFC effectively predicted non-deleterious mutations on an in-house validation dataset that is free of biases seen in the publicly available training datasets. Furthermore, experimental screening of a limited number of predictions from the model ({\textless}10{\textasciicircum}2 designs) identified affinity-enhancing mutations in two unrelated SARS-CoV-2 antibodies, resulting in constructs with up to 1000-fold increased binding to the SARS-COV-2 RBD. Our findings indicate that accurate prediction and screening of non-deleterious mutations using machine learning offers a powerful approach to improving antibody affinity.},
	journal = {Communications Chemistry},
	author = {Clark, Thomas and Subramanian, Vidya and Jayaraman, Akila and Fitzpatrick, Emmett and Gopal, Ranjani and Pentakota, Niharika and Rurak, Troy and Anand, Shweta and Viglione, Alexander and Raman, Rahul and Tharakaraman, Kannan and Sasisekharan, Ram},
	year = {2023},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 计算化学模型 EndNote Refs: 计算化学模型\#11 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}计算化学模型.Data{\textbackslash}PDF{\textbackslash}1079223556{\textbackslash}s42004-023-01037-7.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, import:EndNote全量, EndNote库:计算化学模型, 分类:AI药物设计\_蛋白与多肽, 主题词:drug screening {\textbar} protein design {\textbar} molecular docking},
}

@article{coassolo_prohormone_2025,
	title = {Prohormone cleavage prediction uncovers a non-incretin anti-obesity peptide},
	url = {https://doi.org/10.1038/s41586-025-08683-y},
	doi = {10.1038/s41586-025-08683-y},
	abstract = {Peptide hormones, a class of pharmacologically active molecules, have a critical role in regulating energy homeostasis. Prohormone convertase 1/3 (also known as PCSK1/3) represents a key enzymatic mechanism in peptide processing, as exemplified with the therapeutic target glucagon-like peptide 1 (GLP-1)1,2. However, the full spectrum of peptides generated by PCSK1 and their functional roles remain largely unknown. Here we use computational drug discovery to systematically map more than 2,600 previously uncharacterized human proteolytic peptide fragments cleaved by prohormone convertases, enabling the identification of novel bioactive peptides. Using this approach, we identified a 12-mer peptide, BRINP2-related peptide (BRP). When administered pharmacologically, BRP reduces food intake and exhibits anti-obesity effects in mice and pigs without inducing nausea or aversion. Mechanistically, BRP administration triggers central FOS activation and acts independently of leptin, GLP-1 receptor and melanocortin 4 receptor. Together, these data introduce a method to identify new bioactive peptides and establish pharmacologically that BRP may be useful for therapeutic modulation of body weight.},
	journal = {Nature},
	author = {Coassolo, Laetitia and B. Danneskiold-Samsøe, Niels and Nguyen, Quennie and Wiggenhorn, Amanda and Zhao, Meng and Wang, David Cheng-Hao and Toomer, David and Lone, Jameel and Wei, Yichao and Patel, Aayan and Liparulo, Irene and Kavi, Deniz and Wat, Lianna W. and Reghupaty, Saranya Chidambaranathan and Kim, Julie Jae and Asemi, Tina and Bielczyk-Maczynska, Ewa and Li, Veronica L. and Moya-Garzon, Maria Dolores and Krentz, Nicole A. J. and Stahl, Andreas and Chou, Danny Hung-Chieh and Luo, Liqun and Svensson, Katrin J.},
	year = {2025},
