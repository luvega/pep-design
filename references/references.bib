@article{oeller_sequence-based_2023,
	title = {Sequence-based prediction of the intrinsic solubility of peptides containing non-natural amino acids},
	doi = {10.1038/s41467-023-42940-w},
	abstract = {Non-natural amino acids are increasingly used as building blocks in the development of peptide-based drugs as they expand the available chemical space to tailor function, half-life and other key properties. However, while the chemical space of modified amino acids (mAAs) such as residues containing post-translational modifications (PTMs) is potentially vast, experimental methods for measuring the developability properties of mAA-containing peptides are expensive and time consuming. To facilitate developability programs through computational methods, we present CamSol-PTM, a method that enables the fast and reliable sequence-based prediction of the intrinsic solubility of mAA-containing peptides in aqueous solution at room temperature. From a computational screening of 50,000 mAA-containing variants of three peptides, we selected five different small-size mAAs for a total number of 37 peptide variants for experimental validation. We demonstrate the accuracy of the predictions by comparing the calculated and experimental solubility values. Our results indicate that the computational screening of mAA-containing peptides can extend by over four orders of magnitude the ability to explore the solubility chemical space of peptides and confirm that our method can accurately assess the solubility of peptides containing mAAs. This method is available as a web server at https://www-cohsoftware.ch.cam.ac.uk/index.php/camsolptm .},
	journal = {Nat Commun},
	author = {Oeller, M. and Kang, R. J. D. and Bolt, H. L. and Gomes Dos Santos, A. L. and Weinmann, A. L. and Nikitidis, A. and Zlatoidsky, P. and Su, W. and Czechtizky, W. and De Maria, L. and Sormanni, P. and Vendruscolo, M.},
	year = {2023},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 计算化学模型 EndNote Refs: 计算化学模型\#4 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}计算化学模型.Data{\textbackslash}PDF{\textbackslash}2388994293{\textbackslash}s41467-023-42940-w.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, import:EndNote全量, EndNote库:计算化学模型, 分类:AI药物设计\_蛋白与多肽, 主题词:T cell {\textbar} drug screening {\textbar} peptide design},
}

@article{zhai_blocking_2021,
	title = {Blocking of the {PD}-1/{PD}-{L1} interaction by a novel cyclic peptide inhibitor for cancer immunotherapy},
	url = {https://doi.org/10.1007/s11427-020-1740-8},
	doi = {10.1007/s11427-020-1740-8},
	abstract = {The interaction of PD-1/PD-L1 allows tumor cells to escape from immune surveillance. Clinical success of the antibody drugs has proven that blockade of PD-1/PD-L1 pathway is a promising strategy for cancer immunotherapy. Here, we developed a cyclic peptide C8 by using Ph.D.-C7C phage display technology. C8 showed high binding affinity with hPD-1 and could effectively interfere the interaction of PD-1/PD-L1. Furthermore, C8 could stimulate CD8+ T cell activation in human peripheral blood mononuclear cells (PBMCs). We also observed that C8 could suppress tumor growth in CT26 and B16-OVA, as well as anti-PD-1 antibody resistant B16 mouse model. CD8 T cells infiltration significantly increased in tumor microenvironment, and IFN-γ secretion by CD8+ T cells in draining lymph nodes also increased. Simultaneously, we exploited T cells depletion models and confirmed that C8 exerted anti-tumor effects via activating CD8+ T cells dependent manner. The interaction model of C8 with hPD-1 was simulated and confirmed by alanine scanning. In conclusion, C8 shows anti-tumor capability by blockade of PD-1/PD-L1 interaction, and C8 may provide an alternative candidate for cancer immunotherapy.},
	journal = {Science China Life Sciences},
	author = {Zhai, Wenjie and Zhou, Xiuman and Zhai, Mingxia and Li, Wanqiong and Ran, Yunhui and Sun, Yixuan and Du, Jiangfeng and Zhao, Wenshan and Xing, Lingxiao and Qi, Yuanming and Gao, Yanfeng},
	year = {2021},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#34 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2745092010{\textbackslash}2021-Science China L-Blocking of the PD-1\_PD-L.pdf [/Codex EndNote Import]},
	keywords = {interferon, T cell, tumor microenvironment, codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, drug screening, molecular docking, peptide design, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:tumor microenvironment {\textbar} T cell {\textbar} drug screening {\textbar} peptide design {\textbar} molecular docking {\textbar} interferon},
