@article{bryant_evobind_2022,
	title = {{EvoBind}: {\textless}em{\textgreater}in silico{\textless}/em{\textgreater} directed evolution of peptide binders with {AlphaFold}},
	url = {https://www.biorxiv.org/content/biorxiv/early/2022/07/23/2022.07.23.501214.full.pdf},
	doi = {10.1101/2022.07.23.501214},
	abstract = {Currently, there is no accurate method to computationally design peptide binders towards a specific protein interface using only a target structure. Experimental methods such as phage display can produce strong binders, but it is impossible to know where these bind without solving the structures. Using AlphaFold2 (AF) and other AI methods to distinguish true binders has proven highly successful but relies on the availability of binding scaffolds. Here, we develop EvoBind, an in silico directed-evolution platform based on AF that designs peptide binders towards an interface using only sequence information. We show that AF can distinguish between native and mutated peptide binders using the plDDT score and find that AF adapts the receptor interface structure to the binders during optimisation. We analyse previously designed minibinder proteins and show that AF can distinguish designed binders from non-binders. We compare ELISA ratios of different peptide binders and find the affinity can not be distinguished among binders, possibly due to varying binding sites and low AF confidence. We test the recovery of binding motifs and find that up to 75\% of motifs are recovered. In principle, EvoBind can be used to design binders towards any interface conditioned on if AF can predict these. We expect that EvoBind will aid experimentalists substantially, providing a starting point for further laboratory analysis and optimisation. We hope that the use of AI-based methods will come to make binder design significantly cheaper and more accurate in tackling unmet clinical needs. EvoBind is freely available at: https://colab.research.google.com/github/patrickbryant1/EvoBind/blob/master/EvoBind.ipynbCompeting Interest StatementP.B. is CEO of Urgenta Labs, a startup that develops targeted peptide binders to tackle neglected diseases.},
	journal = {bioRxiv},
	author = {Bryant, Patrick and Elofsson, Arne},
	year = {2022},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 计算化学模型 EndNote Refs: 计算化学模型\#45 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}计算化学模型.Data{\textbackslash}PDF{\textbackslash}3943643119{\textbackslash}2022.07.23.501214v1.full.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, import:EndNote全量, EndNote库:计算化学模型, 分类:AI药物设计\_蛋白与多肽, 主题词:drug screening {\textbar} protein design {\textbar} peptide design {\textbar} molecular docking},
}

