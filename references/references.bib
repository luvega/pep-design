@article{zou_structure-based_2025,
	title = {A structure-based framework for selective inhibitor design and optimization},
	url = {https://doi.org/10.1038/s42003-025-07840-3},
	doi = {10.1038/s42003-025-07840-3},
	abstract = {Structure-based drug design aims to create active compounds with favorable properties by analyzing target structures. Recently, deep generative models have facilitated structure-specific molecular generation. However, many methods are limited by inadequate pharmaceutical data, resulting in suboptimal molecular properties and unstable conformations. Additionally, these approaches often overlook binding pocket interactions and struggle with selective inhibitor design. To address these challenges, we developed a framework called Coarse-grained and Multi-dimensional Data-driven molecular generation (CMD-GEN). CMD-GEN bridges ligand-protein complexes with drug-like molecules by utilizing coarse-grained pharmacophore points sampled from diffusion model, enriching training data. Through a hierarchical architecture, it decomposes three-dimensional molecule generation within the pocket into pharmacophore point sampling, chemical structure generation, and conformation alignment, mitigating instability issues. CMD-GEN outperforms other methods in benchmark tests and controls drug-likeness effectively. Furthermore, CMD-GEN excels in cases across three synthetic lethal targets, and wet-lab validation with PARP1/2 inhibitors confirms its potential in selective inhibitor design.},
	journal = {Communications Biology},
	author = {Zou, Yurong and Guo, Tao and Fu, Zhiyuan and Guo, Zhongning and Bo, Weichen and Yan, Dengjie and Wang, Qiantao and Zeng, Jun and Xu, Dingguo and Wang, Taijin and Chen, Lijuan},
	year = {2025},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#19 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}3997034892{\textbackslash}2025-Communications-A structure-based framewor.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, generative model, molecular docking, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:molecular docking {\textbar} generative model},
