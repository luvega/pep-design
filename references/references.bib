@article{householder_novo_2025,
	title = {De novo design and structure of a peptide–centric {TCR} mimic binding module},
	url = {https://www.science.org/doi/abs/10.1126/science.adv3813},
	doi = {10.1126/science.adv3813},
	abstract = {T cell receptor (TCR) mimics offer a promising platform for tumor-specific targeting of peptide–major histocompatibility complex (pMHC) in cancer immunotherapy. In this study, we designed a de novo α-helical TCR mimic (TCRm) specific for the NY-ESO-1 peptide presented by human leukocyte antigen (HLA)–A*02, achieving high on-target specificity with nanomolar affinity (dissociation constant Kd = 9.5 nM). The structure of the TCRm-pMHC complex at 2.05-Å resolution revealed a rigid TCR-like docking mode with an unusual degree of focus on the up-facing NY-ESO-1 side chains, suggesting the potential for reduced off-target reactivity. Indeed, a structure-informed in silico screen of 14,363 HLA-A*02 peptides correctly predicted two off-target peptides, yet our TCRm maintained peptide selectivity and cytotoxicity as a T cell engager. These results represent a path for precision targeting of tumor antigens with peptide-focused α-helical TCR mimics. Diseased and infected cells can be recognized through peptide antigens presented on the surface of the cell by major histocompatibility complex (MHC) proteins. Whereas the T cell receptor is nature’s solution for recognizing peptide antigen–loaded MHCs, smaller proteins synthesized for this purpose could be transformative for diagnostic tools and immunotherapies. Liu et al., Johansen et al., and Householder et al. developed computational and experimental pipelines to facilitate the rapid design and validation of proteins that could recognize peptides from viral proteins, tumor-associated proteins, or neoantigens when presented by MHC molecules, with high specificity and low off-target recognition (see the Perspective by Hickok and Stromnes). When incorporated as the recognition domain for a chimeric antigen receptor and expressed in T cells, these de novo–designed peptide-MHC binders could induce signaling and on-target cell killing. —Sarah H. Ross},
	journal = {Science},
	author = {Householder, Karsten D. and Xiang, Xinyu and Jude, Kevin M. and Deng, Arthur and Obenaus, Matthias and Zhao, Yang and Wilson, Steven C. and Chen, Xiaojing and Wang, Nan and Garcia, K. Christopher},
	year = {2025},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#80 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}4178337824{\textbackslash}2025-Science-De novo design and structure of a.pdf [/Codex EndNote Import]},
	keywords = {T cell, codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, drug screening, protein design, molecular docking, peptide design, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:T cell {\textbar} drug screening {\textbar} protein design {\textbar} peptide design {\textbar} molecular docking},
	annote = {Codex collection: AI drug design, protein and peptide {\textbar} EndNote library: 蛋白质分子设计 {\textbar} EndNote ref id: 80 {\textbar} Local PDF path: F:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}4178337824{\textbackslash}2025-Science-De novo design and structure of a.pdf {\textbar} Extracted text: F:{\textbackslash}Endnote参考文献{\textbackslash}\_kb{\textbackslash}raw{\textbackslash}extracted\_text{\textbackslash}protein-molecular-design{\textbackslash}ref-80.txt},
