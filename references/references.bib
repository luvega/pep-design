@article{yin_leveraging_2024,
	title = {Leveraging machine learning models for peptide–protein interaction prediction},
	url = {http://dx.doi.org/10.1039/D3CB00208J},
	doi = {10.1039/D3CB00208J},
	abstract = {Peptides play a pivotal role in a wide range of biological activities through participating in up to 40\% protein–protein interactions in cellular processes. They also demonstrate remarkable specificity and efficacy, making them promising candidates for drug development. However, predicting peptide–protein complexes by traditional computational approaches, such as docking and molecular dynamics simulations, still remains a challenge due to high computational cost, flexible nature of peptides, and limited structural information of peptide–protein complexes. In recent years, the surge of available biological data has given rise to the development of an increasing number of machine learning models for predicting peptide–protein interactions. These models offer efficient solutions to address the challenges associated with traditional computational approaches. Furthermore, they offer enhanced accuracy, robustness, and interpretability in their predictive outcomes. This review presents a comprehensive overview of machine learning and deep learning models that have emerged in recent years for the prediction of peptide–protein interactions.},
	journal = {RSC Chemical Biology},
	author = {Yin, Song and Mi, Xuenan and Shukla, Diwakar},
	year = {2024},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#65 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2577995284{\textbackslash}2024-RSC Chemical Bi-Leveraging machine learni.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, generative model, molecular docking, peptide design, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:peptide design {\textbar} molecular docking {\textbar} generative model},
	annote = {Codex collection: AI drug design, protein and peptide {\textbar} EndNote library: 蛋白质分子设计 {\textbar} EndNote ref id: 65 {\textbar} Local PDF path: F:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2577995284{\textbackslash}2024-RSC Chemical Bi-Leveraging machine learni.pdf {\textbar} Extracted text: F:{\textbackslash}Endnote参考文献{\textbackslash}\_kb{\textbackslash}raw{\textbackslash}extracted\_text{\textbackslash}protein-molecular-design{\textbackslash}ref-65.txt},
