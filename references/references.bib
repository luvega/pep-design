@article{kortemme_novo_2024,
	title = {De novo protein design—{From} new structures to programmable functions},
	url = {https://www.sciencedirect.com/science/article/pii/S0092867423014022},
	doi = {10.1016/j.cell.2023.12.028},
	abstract = {Summary Methods from artificial intelligence (AI) trained on large datasets of sequences and structures can now “write” proteins with new shapes and molecular functions de novo, without starting from proteins found in nature. In this Perspective, I will discuss the state of the field of de novo protein design at the juncture of physics-based modeling approaches and AI. New protein folds and higher-order assemblies can be designed with considerable experimental success rates, and difficult problems requiring tunable control over protein conformations and precise shape complementarity for molecular recognition are coming into reach. Emerging approaches incorporate engineering principles—tunability, controllability, and modularity—into the design process from the beginning. Exciting frontiers lie in deconstructing cellular functions with de novo proteins and, conversely, constructing synthetic cellular signaling from the ground up. As methods improve, many more challenges are unsolved.},
	journal = {Cell},
	author = {Kortemme, Tanja},
	year = {2024},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#4 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}4080316163{\textbackslash}2024-Cell-De novo protein design—From new stru.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, drug screening, protein design, artificial intelligence, deep learning, synthetic signaling, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:drug screening {\textbar} protein design},
