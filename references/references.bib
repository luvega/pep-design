@article{johansen_novo-designed_2025,
	title = {De novo-designed {pMHC} binders facilitate {T} cell–mediated cytotoxicity toward cancer cells},
	url = {https://www.science.org/doi/abs/10.1126/science.adv0422},
	doi = {10.1126/science.adv0422},
	abstract = {The recognition of intracellular antigens by CD8+ T cells through T cell receptors (TCRs) is central for adaptive immunity against infections and cancer. However, the identification of TCRs from patient material remains complex. We present a rapid de novo minibinder (miBd) design platform leveraging state-of-the-art generative models to engineer miBds targeting the cancer-associated peptide-bound major histocompatibility complex (pMHC) SLLMWITQC/HLA-A*02:01 (NY-ESO-1). Incorporating in silico cross-panning enabled computational prescreening of specificity, and molecular dynamics simulations allowed for improved predictability of in vitro success. We identified a high-affinity NY-ESO-1 binder and confirmed its structure using cryo–electron microscopy, which, when incorporated in a chimeric antigen receptor, induced killing of NY-ESO-1+ melanoma cells. We further designed and validated binders to a neoantigen pMHC complex, RVTDESILSY/HLA-A*01:01, with unknown structure, demonstrating the potential for precision immunotherapy. Diseased and infected cells can be recognized through peptide antigens presented on the surface of the cell by major histocompatibility complex (MHC) proteins. Whereas the T cell receptor is nature’s solution for recognizing peptide antigen–loaded MHCs, smaller proteins synthesized for this purpose could be transformative for diagnostic tools and immunotherapies. Liu et al., Johansen et al., and Householder et al. developed computational and experimental pipelines to facilitate the rapid design and validation of proteins that could recognize peptides from viral proteins, tumor-associated proteins, or neoantigens when presented by MHC molecules, with high specificity and low off-target recognition (see the Perspective by Hickok and Stromnes). When incorporated as the recognition domain for a chimeric antigen receptor and expressed in T cells, these de novo–designed peptide-MHC binders could induce signaling and on-target cell killing. —Sarah H. Ross},
	journal = {Science},
	author = {Johansen, Kristoffer Haurum and Wolff, Darian Stephan and Scapolo, Beatrice and Fernández-Quintero, Monica L. and Risager Christensen, Charlotte and Loeffler, Johannes R. and Rivera-de-Torre, Esperanza and Overath, Max D. and Kjærgaard Munk, Kamilla and Morell, Oliver and Viuff, Marie Christine and Lacunza, Iñigo and Damm Englund, Alberte T. and Due, Mathilde and Gharpure, Anant and Forli, Stefano and Rodriguez Pardo, Carlos and Tamhane, Tripti and Qingjie Andersen, Emma and Haldrup Björnsson, Kasper and Fernandes, Jordan Sylvester and Voss, Lasse Frank and Thumtecho, Suthimon and Ward, Andrew B. and Ormhøj, Maria and Reker Hadrup, Sine and Jenkins, Timothy P.},
	year = {2025},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#79 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}4097824413{\textbackslash}2025-Science-De novo-designed pMHC binders fac.pdf [/Codex EndNote Import]},
