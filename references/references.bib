@article{rettie_accurate_2025,
	title = {Accurate de novo design of high-affinity protein-binding macrocycles using deep learning},
	url = {https://doi.org/10.1038/s41589-025-01929-w},
	doi = {10.1038/s41589-025-01929-w},
	abstract = {Developing macrocyclic binders to therapeutic proteins typically relies on large-scale screening methods that are resource intensive and provide little control over binding mode. Despite progress in protein design, there are currently no robust approaches for de novo design of protein-binding macrocycles. Here we introduce RFpeptides, a denoising diffusion-based pipeline for designing macrocyclic binders against protein targets of interest. We tested 20 or fewer designed macrocycles against each of four diverse proteins and obtained binders with medium to high affinity against all targets. For one of the targets, Rhombotarget A (RbtA), we designed a high-affinity binder (Kd {\textless} 10 nM) despite starting from the predicted target structure. X-ray structures for macrocycle-bound myeloid cell leukemia 1, γ-aminobutyric acid type A receptor-associated protein and RbtA complexes match closely with the computational models, with a Cα root-mean-square deviation {\textless} 1.5 Å to the design models. RFpeptides provides a framework for rapid and custom design of macrocyclic peptides for diagnostic and therapeutic applications.},
	journal = {Nature Chemical Biology},
	author = {Rettie, Stephen A. and Juergens, David and Adebomi, Victor and Bueso, Yensi Flores and Zhao, Qinqin and Leveille, Alexandria N. and Liu, Andi and Bera, Asim K. and Wilms, Joana A. and Üffing, Alina and Kang, Alex and Brackenbrough, Evans and Lamb, Mila and Gerben, Stacey R. and Murray, Analisa and Levine, Paul M. and Schneider, Maika and Vasireddy, Vibha and Ovchinnikov, Sergey and Weiergräber, Oliver H. and Willbold, Dieter and Kritzer, Joshua A. and Mougous, Joseph D. and Baker, David and DiMaio, Frank and Bhardwaj, Gaurav},
	year = {2025},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#86 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}1340803470{\textbackslash}2025-Nature Chemical-Accurate de novo design o.pdf [/Codex EndNote Import]},
