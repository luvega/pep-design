@article{liu_design_2025,
	title = {Design of high-specificity binders for peptide–{MHC}-{I} complexes},
	url = {https://www.science.org/doi/abs/10.1126/science.adv0185},
	doi = {10.1126/science.adv0185},
	abstract = {Class I major histocompatibility complex (MHC-I) molecules present peptides derived from intracellular antigens on the cell surface for immune surveillance. Proteins that recognize peptide–MHC-I (pMHCI) complexes with specificity for diseased cells could have considerable therapeutic utility. Specificity requires recognition of outward-facing amino acid residues within the disease-associated peptide as well as avoidance of extensive contacts with ubiquitously expressed MHC. We used RFdiffusion to design pMHCI-binding proteins that make extensive contacts with the peptide and identified specific binders for 11 target pMHCs starting from either experimental or predicted pMHCI structures. Upon incorporation into chimeric antigen receptors, designs for eight targets conferred peptide-specific T cell activation. Our approach should have broad utility for both protein- and cell-based pMHCI targeting. Diseased and infected cells can be recognized through peptide antigens presented on the surface of the cell by major histocompatibility complex (MHC) proteins. Whereas the T cell receptor is nature’s solution for recognizing peptide antigen–loaded MHCs, smaller proteins synthesized for this purpose could be transformative for diagnostic tools and immunotherapies. Liu et al., Johansen et al., and Householder et al. developed computational and experimental pipelines to facilitate the rapid design and validation of proteins that could recognize peptides from viral proteins, tumor-associated proteins, or neoantigens when presented by MHC molecules, with high specificity and low off-target recognition (see the Perspective by Hickok and Stromnes). When incorporated as the recognition domain for a chimeric antigen receptor and expressed in T cells, these de novo–designed peptide-MHC binders could induce signaling and on-target cell killing. —Sarah H. Ross},
	journal = {Science},
	author = {Liu, Bingxu and Greenwood, Nathan F. and Bonzanini, Julia E. and Motmaen, Amir and Meyerberg, Jeremy and Dao, Tao and Xiang, Xinyu and Ault, Russell and Sharp, Jazmin and Wang, Chunyu and Visani, Gian Marco and Vafeados, Dionne K. and Roullier, Nicole and Nourmohammad, Armita and Scheinberg, David A. and Garcia, K. Christopher and Baker, David},
	year = {2025},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#77 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}0371521014{\textbackslash}2025-Science-Design of high-specificity binder.pdf [/Codex EndNote Import]},
	keywords = {T cell, codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, generative model, drug screening, protein design, peptide design, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:T cell {\textbar} drug screening {\textbar} protein design {\textbar} peptide design {\textbar} generative model},
