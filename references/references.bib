@article{wan_machine_2024,
	title = {Machine learning for antimicrobial peptide identification and design},
	url = {https://doi.org/10.1038/s44222-024-00152-x},
	doi = {10.1038/s44222-024-00152-x},
	abstract = {Artificial intelligence (AI) and machine learning (ML) models are being deployed in many domains of society and have recently reached the field of drug discovery. Given the increasing prevalence of antimicrobial resistance, as well as the challenges intrinsic to antibiotic development, there is an urgent need to accelerate the design of new antimicrobial therapies. Antimicrobial peptides (AMPs) are therapeutic agents for treating bacterial infections, but their translation into the clinic has been slow owing to toxicity, poor stability, limited cellular penetration and high cost, among other issues. Recent advances in AI and ML have led to breakthroughs in our abilities to predict biomolecular properties and structures and to generate new molecules. The ML-based modelling of peptides may overcome some of the disadvantages associated with traditional drug discovery and aid the rapid development and translation of AMPs. Here, we provide an introduction to this emerging field and survey ML approaches that can be used to address issues currently hindering AMP development. We also outline important limitations that can be addressed for the broader adoption of AMPs in clinical practice, as well as new opportunities in data-driven peptide design.},
	journal = {Nature Reviews Bioengineering},
	author = {Wan, Fangping and Wong, Felix and Collins, James J. and de la Fuente-Nunez, Cesar},
	year = {2024},
	note = {[Codex EndNote Import] Themes: 单细胞与空间组学方法数据库 Theme Slugs: single-cell-spatial-methods EndNote Libraries: 方法比较及数据库 EndNote Refs: 方法比较及数据库\#622 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}方法比较及数据库.Data{\textbackslash}PDF{\textbackslash}2137386703{\textbackslash}2024-Nature Reviews-Machine learning for antim.pdf [/Codex EndNote Import]},
	keywords = {import:EndNote全量, codex-collection:single-cell-spatial-methods, 分类:单细胞与空间组学方法数据库, EndNote库:方法比较及数据库, 主题词:drug screening {\textbar} peptide design},
