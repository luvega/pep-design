@article{wang_peptide_2026,
	title = {A peptide immunomodulator activates {MST1} to expand and stabilize murine and human regulatory {T} cells for immune tolerance},
	url = {https://www.science.org/doi/abs/10.1126/scitranslmed.adz0672},
	doi = {10.1126/scitranslmed.adz0672},
	abstract = {The expansion and potentiation of regulatory T cells (Treg cells) offer an appealing approach for achieving immune tolerance and controlling overactive immune responses across a range of diseases. Current therapeutic approaches to expanding and improving function of Treg cells have predominantly relied on protein-based biologics, such as recombinant interleukin-2 (IL-2); in contrast, peptide-based interventions that can expand Treg cells with improved functional stability, enhanced specificity, and favorable safety profiles remain underexplored. Here, using a deep learning model, we identified a hexapeptide (DLST-6P) that preferentially expands both human and murine Treg cells while preserving their stability. When tested in multiple autoimmune and inflammatory disorders, including a humanized mouse model of graft-versus-host disease, DLST-6P exhibited therapeutic efficacy both as a monotherapy and in combination with low-dose IL-2. Mechanistically, we found that DLST-6P directly targets and activates mammalian Ste20-like kinase 1 (MST1) by promoting homodimer formation. After activation by DLST-6P treatment, MST1 phosphorylated the master Treg cell transcription factor forkhead box protein P3 (FOXP3) at serine-390. This promoted the association of FOXP3 with the acetyltransferase tat-interacting protein 60, leading to enhanced FOXP3 acetylation and protein stabilization. Simultaneously, we observed that DLST-6P–mediated activation of MST1 alleviated suppressor of cytokine signaling–mediated inhibition of IL-2 signaling in Treg cells, thereby sensitizing the cells to IL-2 stimulation. Together, these findings unveil a dual mechanistic program through which pharmacological activation of MST1 can boost Treg cell expansion and stability and highlight the translational potential of DLST-6P as a peptide-based immunomodulator for treating autoimmune and inflammatory disorders. A dual-action peptide that activates MST1 can expand and stabilize murine and human regulatory T cells to induce therapeutic immune tolerance. Therapies aimed to induce or improve the function of regulatory T cells (Treg cells) have long been sought as a treatment for autoimmune and inflammatory disorders. However, the most successful approach, low-dose interleukin-2 (IL-2), is not specific to Treg cells and can result in development of antidrug antibodies. To target Treg cells more specifically and avoid the antidrug antibody problem with protein-based therapies in general, Wang et\&nbsp;al. used a deep learning model to identify a hexapeptide, DLST-6P, that specifically augmented Treg cell expansion and function. The authors found a dual mechanism of action, wherein DLST-6P both drove the stabilization of the key Treg cell transcription factor FOXP3 via a noncanonical MST1-dependent pathway and sensitized these more stable Treg cells to IL-2 signaling. In vivo, the authors found that DLST-6P was efficacious at controlling inflammation in murine models of colitis, periodontitis, and xenogeneic graft-versus-host disease when used alone or as part of an IL-2–sparing strategy in combination with lose-dose IL-2. Together, these data highlight the therapeutic potential of this MST1-targeting hexapeptide and highlight the value of computational drug discovery. —Courtney Malo},
	journal = {Science Translational Medicine},
	author = {Wang, Yu and Liu, Xinnan and Li, Xiaoxue and Zhao, Linfeng and Chen, Hongli and Gong, Xuyan and Xu, Junji and Zhang, Jian and Liu, Zhiduo and Sun, Yao},
	year = {2026},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 多肽设计; 蛋白质分子设计 EndNote Refs: 多肽设计\#1; 蛋白质分子设计\#145 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}多肽设计.Data{\textbackslash}PDF{\textbackslash}0021146708{\textbackslash}scitranslmed.adz0672.pdf; E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2184260220{\textbackslash}2026-Science Transla-A peptide immunomodulator.pdf [/Codex EndNote Import]},
	keywords = {T cell, codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, peptide design, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:T cell {\textbar} peptide design, EndNote库:多肽设计},
	annote = {Codex collection: AI drug design, protein and peptide {\textbar} EndNote library: 蛋白质分子设计 {\textbar} EndNote ref id: 145 {\textbar} Local PDF path: F:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2184260220{\textbackslash}2026-Science Transla-A peptide immunomodulator.pdf},
