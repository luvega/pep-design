	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, artificial intelligence, biomarkers, cancer, TCGA, classification, epigenomic, genomic, machine learning, molecular, pathology, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计},
