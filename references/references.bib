@article{sun_deep_2024,
	title = {A deep attention model for wide-genome protein-peptide binding affinity prediction at a sequence level},
	url = {https://www.sciencedirect.com/science/article/pii/S0141813024046166},
	doi = {10.1016/j.ijbiomac.2024.133811},
	abstract = {Peptides are pivotal in numerous biological activities by engaging in up to 40 \% of protein-protein interactions in many cellular processes. Due to their exceptional specificity and effectiveness, peptides have emerged as promising candidates for drug design. However, accurately predicting protein-peptide binding affinity remains a challenging. Aiming at the problem, we develop a prediction model PepPAP based on convolutional neural network and multi-head attention, which relies solely on sequence features. These features include physicochemical properties, intrinsic disorder, sequence encoding, and especially interface propensity which is extracted from 16,689 non-redundant protein-peptide complexes. Notably, the adopted regression stratification cross-validation scheme proposed in our previous work is beneficial to improve the prediction for the cases with extreme binding affinity values. On three benchmark test datasets: T100, a series of peptides targeting to PDZ domain and CXCR4, PepPAP shows excellent performance, outperforming the existing methods and demonstrating its good generalization ability. Furthermore, PepPAP has good results in binary interaction prediction, and the analysis of the feature space distribution visualization highlights PepPAP's effectiveness. To the best of our knowledge, PepPAP is the first sequence-based deep attention model for wide-genome protein-peptide binding affinity prediction, and holds the potential to offer valuable insights for the peptide-based drug design.},
	journal = {International Journal of Biological Macromolecules},
	author = {Sun, Xiaohan and Wu, Zhixiang and Su, Jingjie and Li, Chunhua},
	year = {2024},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#62 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2897875437{\textbackslash}2024-International J-A deep attention model fo.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, generative model, drug screening, molecular docking, peptide design, Binding affinity prediction, Convolutional neural network, Interface propensity, Multi-head attention, Protein-peptide interactions, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, 主题词:drug screening {\textbar} peptide design {\textbar} molecular docking {\textbar} generative model, EndNote库:蛋白质分子设计},
	annote = {Codex collection: AI drug design, protein and peptide {\textbar} EndNote library: 蛋白质分子设计 {\textbar} EndNote ref id: 62 {\textbar} Local PDF path: F:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2897875437{\textbackslash}2024-International J-A deep attention model fo.pdf {\textbar} Extracted text: F:{\textbackslash}Endnote参考文献{\textbackslash}\_kb{\textbackslash}raw{\textbackslash}extracted\_text{\textbackslash}protein-molecular-design{\textbackslash}ref-62.txt},
