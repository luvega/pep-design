@article{zhao_tryptophan_2021,
	title = {Tryptophan 2,3-dioxygenase 2 controls {M2} macrophages polarization to promote esophageal squamous cell carcinoma progression via {AKT}/{GSK3beta}/{IL}-8 signaling pathway},
	url = {https://www.ncbi.nlm.nih.gov/pubmed/34589400},
	doi = {10.1016/j.apsb.2021.03.009},
	abstract = {Tryptophan 2,3-dioxygnease 2 (TDO2) is specific for metabolizing tryptophan to kynurenine (KYN), which plays a critical role in mediating immune escape of cancer. Although accumulating evidence demonstrates that TDO2 overexpression is implicated in the development and progression of multiple cancers, its tumor-promoting role in esophageal squamous cell carcinoma (ESCC) remains unclear. Here, we observed that TDO2 was overexpressed in ESCC tissues and correlated significantly with lymph node metastasis, advanced clinical stage, and unfavorable prognosis. Functional experiments showed that TDO2 promoted tumor cell proliferation, migration, and colony formation, which could be prevented by inhibition of TDO2 and aryl hydrocarbon receptor (AHR). Further experimentation demonstrated that TDO2 could promote the tumor growth of KYSE150 tumor-bearing model, tumor burden of C57BL/6 mice with ESCC induced by 4-NQO, enhance the expression of phosphorylated AKT, with subsequent phosphorylation of GSK3beta, and polarization of M2 macrophages by upregulating interleukin-8 (IL-8) to accelerate tumor progression in the tumor microenvironment (TME). Collectively, our results discovered that TDO2 could upregulate IL-8 through AKT/GSK3beta to direct the polarization of M2 macrophages in ESCC, and suggested that TDO2 could represent as an attractive therapeutic target and prognostic marker to ESCC.},
	journal = {Acta Pharm Sin B},
	author = {Zhao, Y. and Sun, J. and Li, Y. and Zhou, X. and Zhai, W. and Wu, Y. and Chen, G. and Gou, S. and Sui, X. and Zhao, W. and Qiu, L. and Yao, Y. and Sun, Y. and Chen, C. and Qi, Y. and Gao, Y.},
	year = {2021},
	note = {[Codex EndNote Import] Themes: 肿瘤核心机制与肿瘤免疫 Theme Slugs: cancer-core EndNote Libraries: Cancers EndNote Refs: Cancers\#1269; Cancers\#34 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}Cancers.Data{\textbackslash}PDF{\textbackslash}1409582566{\textbackslash}1-s2.0-S2211383521000800-main.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:cancer-core, import:EndNote全量, EndNote库:Cancers, 分类:肿瘤核心机制与肿瘤免疫, 主题词:colorectal cancer {\textbar} breast cancer {\textbar} tumor microenvironment {\textbar} tumor-associated macrophage, 主题词:tumor microenvironment {\textbar} tumor-associated macrophage},
