@article{du_machine_2024,
	title = {Machine learning-aided generative molecular design},
	url = {https://doi.org/10.1038/s42256-024-00843-5},
	doi = {10.1038/s42256-024-00843-5},
	abstract = {Machine learning has provided a means to accelerate early-stage drug discovery by combining molecule generation and filtering steps in a single architecture that leverages the experience and design preferences of medicinal chemists. However, designing machine learning models that can achieve this on the fly to the satisfaction of medicinal chemists remains a challenge owing to the enormous search space. Researchers have addressed de novo design of molecules by decomposing the problem into a series of tasks determined by design criteria. Here we provide a comprehensive overview of the current state of the art in molecular design using machine learning models as well as important design decisions, such as the choice of molecular representations, generative methods and optimization strategies. Subsequently, we present a collection of practical applications in which the reviewed methodologies have been experimentally validated, encompassing both academic and industrial efforts. Finally, we draw attention to the theoretical, computational and empirical challenges in deploying generative machine learning and highlight future opportunities to better align such approaches to achieve realistic drug discovery end points.},
	journal = {Nature Machine Intelligence},
	author = {Du, Yuanqi and Jamasb, Arian R. and Guo, Jeff and Fu, Tianfan and Harris, Charles and Wang, Yingheng and Duan, Chenru and Liò, Pietro and Schwaller, Philippe and Blundell, Tom L.},
	year = {2024},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#149 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2630602167{\textbackslash}2024-Nature Machine-Machine learning-aided gen.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, generative model, drug screening, molecular docking, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:drug screening {\textbar} molecular docking {\textbar} generative model},
	annote = {Codex collection: AI drug design, protein and peptide {\textbar} EndNote library: 蛋白质分子设计 {\textbar} EndNote ref id: 149 {\textbar} Local PDF path: F:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}2630602167{\textbackslash}2024-Nature Machine-Machine learning-aided gen.pdf {\textbar} Extracted text: F:{\textbackslash}Endnote参考文献{\textbackslash}\_kb{\textbackslash}raw{\textbackslash}extracted\_text{\textbackslash}protein-molecular-design{\textbackslash}ref-149.txt},
