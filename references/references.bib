@article{lu_novo_2024,
	title = {De novo design of drug-binding proteins with predictable binding energy and specificity},
	url = {https://www.science.org/doi/abs/10.1126/science.adl5364},
	doi = {10.1126/science.adl5364},
	abstract = {The de novo design of small molecule–binding proteins has seen exciting recent progress; however, high-affinity binding and tunable specificity typically require laborious screening and optimization after computational design. We developed a computational procedure to design a protein that recognizes a common pharmacophore in a series of poly(ADP-ribose) polymerase–1 inhibitors. One of three designed proteins bound different inhibitors with affinities ranging from \&lt;5 nM to low micromolar. X-ray crystal structures confirmed the accuracy of the designed protein-drug interactions. Molecular dynamics simulations informed the role of water in binding. Binding free energy calculations performed directly on the designed models were in excellent agreement with the experimentally measured affinities. We conclude that de novo design of high-affinity small molecule–binding proteins with tuned interaction energies is feasible entirely from computation. Recent advances in protein design have benefited greatly from machine learning but usually do not consider the physics and chemistry of protein-protein or protein-ligand interactions. Such methods can generate many potential structures but typically require considerable screening, validation, and optimization. Using a method that considers local structure of interacting chemical groups, Lu et al. focused on developing a smaller number of protein designs for binding polar drug molecules. They screened three top-scoring designs and identified one that bound to the desired small molecule with subnanomolar affinity even without laborious optimization. Experimental validation and computational work confirmed the design accuracy and revealed a correlation between predicted and observed binding affinities for related drug molecules. These results offer a promising approach for the design of high-affinity drug-binding proteins. —Michael A. Funk},
	journal = {Science},
	author = {Lu, Lei and Gou, Xuxu and Tan, Sophia K. and Mann, Samuel I. and Yang, Hyunjun and Zhong, Xiaofang and Gazgalis, Dimitrios and Valdiviezo, Jesús and Jo, Hyunil and Wu, Yibing and Diolaiti, Morgan E. and Ashworth, Alan and Polizzi, Nicholas F. and DeGrado, William F.},
	year = {2024},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#10 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}1075885872{\textbackslash}2024-Science-De novo design of drug-binding pr.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, drug screening, protein design, molecular docking, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计, 主题词:drug screening {\textbar} protein design {\textbar} molecular docking},
	annote = {Codex collection: AI drug design, protein and peptide {\textbar} EndNote library: 蛋白质分子设计 {\textbar} EndNote ref id: 10 {\textbar} Local PDF path: F:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}1075885872{\textbackslash}2024-Science-De novo design of drug-binding pr.pdf {\textbar} Extracted text: F:{\textbackslash}Endnote参考文献{\textbackslash}\_kb{\textbackslash}raw{\textbackslash}extracted\_text{\textbackslash}protein-molecular-design{\textbackslash}ref-10.txt},
