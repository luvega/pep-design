@article{cattaneo_identification_2023,
	title = {Identification of patient-specific {CD4}+ and {CD8}+ {T} cell neoantigens through {HLA}-unbiased genetic screens},
	url = {https://doi.org/10.1038/s41587-022-01547-0},
	doi = {10.1038/s41587-022-01547-0},
	abstract = {Cancer neoantigens that arise from tumor mutations are drivers of tumor-specific T cell responses, but identification of T cell-recognized neoantigens in individual patients is challenging. Previous methods have restricted antigen discovery to selected HLA alleles, thereby limiting the breadth of neoantigen repertoires that can be uncovered. Here, we develop a genetic neoantigen screening system that allows sensitive identification of CD4+ and CD8+ T cell-recognized neoantigens across patients’ complete HLA genotypes.},
	journal = {Nature Biotechnology},
	author = {Cattaneo, Chiara M. and Battaglia, Thomas and Urbanus, Jos and Moravec, Ziva and Voogd, Rhianne and de Groot, Rosa and Hartemink, Koen J. and Haanen, John B. A. G. and Voest, Emile E. and Schumacher, Ton N. and Scheper, Wouter},
