@article{xie_neoantigens_2023,
	title = {Neoantigens: promising targets for cancer therapy},
	url = {https://doi.org/10.1038/s41392-022-01270-x},
	doi = {10.1038/s41392-022-01270-x},
	abstract = {Recent advances in neoantigen research have accelerated the development and regulatory approval of tumor immunotherapies, including cancer vaccines, adoptive cell therapy and antibody-based therapies, especially for solid tumors. Neoantigens are newly formed antigens generated by tumor cells as a result of various tumor-specific alterations, such as genomic mutation, dysregulated RNA splicing, disordered post-translational modification, and integrated viral open reading frames. Neoantigens are recognized as non-self and trigger an immune response that is not subject to central and peripheral tolerance. The quick identification and prediction of tumor-specific neoantigens have been made possible by the advanced development of next-generation sequencing and bioinformatic technologies. Compared to tumor-associated antigens, the highly immunogenic and tumor-specific neoantigens provide emerging targets for personalized cancer immunotherapies, and serve as prospective predictors for tumor survival prognosis and immune checkpoint blockade responses. The development of cancer therapies will be aided by understanding the mechanism underlying neoantigen-induced anti-tumor immune response and by streamlining the process of neoantigen-based immunotherapies. This review provides an overview on the identification and characterization of neoantigens and outlines the clinical applications of prospective immunotherapeutic strategies based on neoantigens. We also explore their current status, inherent challenges, and clinical translation potential.},
	journal = {Signal Transduction and Targeted Therapy},
	author = {Xie, Na and Shen, Guobo and Gao, Wei and Huang, Zhao and Huang, Canhua and Fu, Li},
	year = {2023},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 计算化学模型 EndNote Refs: 计算化学模型\#39 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}计算化学模型.Data{\textbackslash}PDF{\textbackslash}2118236672{\textbackslash}s41392-022-01270-x.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, import:EndNote全量, EndNote库:计算化学模型, 分类:AI药物设计\_蛋白与多肽, 主题词:T cell {\textbar} peptide design {\textbar} cGAS-STING},
}

@article{kiriyama_d-amino_2016,
	title = {D-{Amino} {Acids} in the {Nervous} and {Endocrine} {Systems}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1155/2016/6494621},
	doi = {10.1155/2016/6494621},
	abstract = {Amino acids are important components for peptides and proteins and act as signal transmitters. Only L-amino acids have been considered necessary in mammals, including humans. However, diverse D-amino acids, such as D-serine, D-aspartate, D-alanine, and D-cysteine, are found in mammals. Physiological roles of these D-amino acids not only in the nervous system but also in the endocrine system are being gradually revealed. N-Methyl-D-aspartate (NMDA) receptors are associated with learning and memory. D-Serine, D-aspartate, and D-alanine can all bind to NMDA receptors. H2S generated from D-cysteine reduces disulfide bonds in receptors and potentiates their activity. Aberrant receptor activity is related to diseases of the central nervous system (CNS), such as Alzheimer’s disease, amyotrophic lateral sclerosis, and schizophrenia. Furthermore, D-amino acids are detected in parts of the endocrine system, such as the pineal gland, hypothalamus, pituitary gland, pancreas, adrenal gland, and testis. D-Aspartate is being investigated for the regulation of hormone release from various endocrine organs. Here we focused on recent findings regarding the synthesis and physiological functions of D-amino acids in the nervous and endocrine systems.},
	journal = {Scientifica},
	author = {Kiriyama, Yoshimitsu and Nochi, Hiromi},
	year = {2016},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 蛋白质分子设计 EndNote Refs: 蛋白质分子设计\#121 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}1839194479{\textbackslash}2016-Scientifica-D-Amino Acids in the Nervous.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, Codex:AI drug design, protein and peptide, EndNote:蛋白质分子设计, 分类:蛋白\_多肽设计, import:EndNote全量, 分类:AI药物设计\_蛋白与多肽, EndNote库:蛋白质分子设计},
	annote = {Codex collection: AI drug design, protein and peptide {\textbar} EndNote library: 蛋白质分子设计 {\textbar} EndNote ref id: 121 {\textbar} Local PDF path: F:{\textbackslash}Endnote参考文献{\textbackslash}蛋白质分子设计.Data{\textbackslash}PDF{\textbackslash}1839194479{\textbackslash}2016-Scientifica-D-Amino Acids in the Nervous.pdf {\textbar} Extracted text: F:{\textbackslash}Endnote参考文献{\textbackslash}\_kb{\textbackslash}raw{\textbackslash}extracted\_text{\textbackslash}protein-molecular-design{\textbackslash}ref-121.txt},
