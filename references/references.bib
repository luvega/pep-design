@article{katkar_macrophage_2023,
	title = {Macrophage states: there's a method in the madness},
	url = {https://doi.org/10.1016/j.it.2023.10.006},
	doi = {10.1016/j.it.2023.10.006},
	abstract = {The era of single-cell biology has witnessed an explosive growth in our inventory of macrophage states, contributing to the notion that diverse macrophage states are unique to each tissue niche.This tenet has recently been challenged by machine-learning approaches that aim to identify what is common (shared), while ignoring what differs. Macrophages, anywhere and everywhere, have been reported to share a universally conserved continuum of inflammatory and non-inflammatory states, regardless of tissues, species, or stimuli.These approaches underscore the importance of maintaining a population-level equilibrium between inflammatory (accelerators) and noninflammatory (brake) macrophages to mount a physiological immune response.These approaches conclude that diseases are either a consequence of population imbalance (too many/too few) and/or inability to switch states (?jammed? brakes/accelerators).},
	journal = {Trends in Immunology},
	author = {Katkar, Gajanan and Ghosh, Pradipta},
	year = {2023},
	note = {[Codex EndNote Import] Themes: AI药物设计\_蛋白与多肽 Theme Slugs: protein-peptide-design EndNote Libraries: 计算化学模型 EndNote Refs: 计算化学模型\#41 Local PDF Paths: E:{\textbackslash}Endnote参考文献{\textbackslash}计算化学模型.Data{\textbackslash}PDF{\textbackslash}3057963872{\textbackslash}PIIS1471490623002132.pdf [/Codex EndNote Import]},
	keywords = {codex-collection:protein-peptide-design, import:EndNote全量, EndNote库:计算化学模型, 分类:AI药物设计\_蛋白与多肽, 主题词:tumor-associated macrophage {\textbar} T cell {\textbar} single-cell RNA-seq {\textbar} interferon},
}

@article{yang_alphafold2_2023,
	title = {{AlphaFold2} and its applications in the fields of biology and medicine},
	url = {https://doi.org/10.1038/s41392-023-01381-z},
	doi = {10.1038/s41392-023-01381-z},
	abstract = {AlphaFold2 (AF2) is an artificial intelligence (AI) system developed by DeepMind that can predict three-dimensional (3D) structures of proteins from amino acid sequences with atomic-level accuracy. Protein structure prediction is one of the most challenging problems in computational biology and chemistry, and has puzzled scientists for 50 years. The advent of AF2 presents an unprecedented progress in protein structure prediction and has attracted much attention. Subsequent release of structures of more than 200 million proteins predicted by AF2 further aroused great enthusiasm in the science community, especially in the fields of biology and medicine. AF2 is thought to have a significant impact on structural biology and research areas that need protein structure information, such as drug discovery, protein design, prediction of protein function, et al. Though the time is not long since AF2 was developed, there are already quite a few application studies of AF2 in the fields of biology and medicine, with many of them having preliminarily proved the potential of AF2. To better understand AF2 and promote its applications, we will in this article summarize the principle and system architecture of AF2 as well as the recipe of its success, and particularly focus on reviewing its applications in the fields of biology and medicine. Limitations of current AF2 prediction will also be discussed.},
